import std/test { assert_eq }
import "./app" { _prev_char, _next_char, _splice }

fun test_splice_inserts_and_replaces() {
    assert_eq(_splice("World", 0, 0, "Hi "), "Hi World")
    assert_eq(_splice("abc", 1, 2, "X"), "aXc")
    assert_eq(_splice("abc", 3, 3, "!"), "abc!")
    assert_eq(_splice("abc", 0, 1, ""), "bc")
}

fun test_char_boundaries_ascii() {
    assert_eq(_prev_char("abc", 2), 1)
    assert_eq(_prev_char("abc", 0), 0)
    assert_eq(_next_char("abc", 1), 2)
    assert_eq(_next_char("abc", 3), 3)
}

fun test_char_boundaries_utf8() {
    // café: c a f then é (0xC3 0xA9), 5 bytes; the caret must jump whole chars.
    assert_eq(_next_char("café", 3), 5)
    assert_eq(_prev_char("café", 5), 3)
}
