import std/test { assert_eq, assert_true, assert_false }
import "./lib" { Theme, Font, Rect }
import "./widget" { Widget, Align, Justify, column, row, button, slider, _hit, _drop_last, _slider_value_at }
import "./layout" { measure, arrange }

// A fixed-size leaf that needs no font, so layout is testable headlessly.
fun fixed(w: Int, h: Int) -> Widget {
    let none: List<Widget> = []
    return column(none).width(w).height(h)
}

fun flexible(h: Int, weight: Int) -> Widget {
    let none: List<Widget> = []
    return column(none).height(h).grow(weight)
}

fun dummy_theme() -> Theme {
    return Theme.dark(Font { id: 0 })
}

fun test_column_measures_with_pad_and_gap() {
    let root = column([fixed(100, 40), fixed(80, 60)]).pad(10).gap(8)
    measure(root, dummy_theme())
    assert_eq(root.mw, 120)
    assert_eq(root.mh, 128)
}

fun test_column_stacks_children() {
    let root = column([fixed(100, 40), fixed(80, 60)]).pad(10).gap(8)
    measure(root, dummy_theme())
    arrange(root, Rect { x: 0, y: 0, w: 200, h: 300 })
    let a = root.kids[0]
    let b = root.kids[1]
    assert_eq(a.box.x, 10)
    assert_eq(a.box.y, 10)
    assert_eq(a.box.w, 100)
    assert_eq(a.box.h, 40)
    assert_eq(b.box.y, 58)
    assert_eq(b.box.h, 60)
}

fun test_row_grow_fills_leftover() {
    let a = fixed(50, 30)
    let b = flexible(30, 1)
    let root = row([a, b]).gap(10)
    measure(root, dummy_theme())
    arrange(root, Rect { x: 0, y: 0, w: 200, h: 30 })
    assert_eq(a.box.x, 0)
    assert_eq(a.box.w, 50)
    assert_eq(b.box.x, 60)
    assert_eq(b.box.w, 140)
}

fun test_hit_finds_button_by_box() {
    let b = button("go", "Go")
    b.box = Rect { x: 10, y: 10, w: 100, h: 40 }
    match _hit(b, 50, 30) {
        Some(h) -> {
            assert_eq(h.id, "go")
            assert_false(h.input)
        },
        None -> {
            assert_true(false)
        },
    }
    match _hit(b, 200, 200) {
        Some(h) -> {
            assert_false(true)
        },
        None -> {
            assert_true(true)
        },
    }
}

fun test_drop_last_handles_utf8() {
    assert_eq(_drop_last("abc"), "ab")
    assert_eq(_drop_last("a"), "")
    assert_eq(_drop_last(""), "")
    // é is two bytes in UTF-8; backspace removes the whole character.
    assert_eq(_drop_last("café"), "caf")
}

fun test_cross_align_center() {
    let a = fixed(100, 40)
    let root = column([a]).align(Align.Center)
    measure(root, dummy_theme())
    arrange(root, Rect { x: 0, y: 0, w: 300, h: 300 })
    assert_eq(a.box.x, 100)
    assert_eq(a.box.w, 100)
}

fun test_main_justify_end() {
    let a = fixed(100, 40)
    let root = column([a]).justify(Justify.End)
    measure(root, dummy_theme())
    arrange(root, Rect { x: 0, y: 0, w: 300, h: 300 })
    assert_eq(a.box.y, 260)
}

fun test_row_justify_between() {
    let a = fixed(50, 30)
    let b = fixed(50, 30)
    let root = row([a, b]).justify(Justify.Between)
    measure(root, dummy_theme())
    arrange(root, Rect { x: 0, y: 0, w: 200, h: 30 })
    assert_eq(a.box.x, 0)
    assert_eq(b.box.x, 150)
}

fun test_slider_value_at() {
    let s = slider("s", 0, 0, 100)
    // usable track = 218 - 2*9 = 200
    s.box = Rect { x: 0, y: 0, w: 218, h: 24 }
    match _slider_value_at(s, "s", 109) {
        Some(v) -> {
            assert_eq(v, 50)
        },
        None -> {
            assert_true(false)
        },
    }
    match _slider_value_at(s, "s", 0) {
        Some(v) -> {
            assert_eq(v, 0)
        },
        None -> {
            assert_true(false)
        },
    }
    match _slider_value_at(s, "s", 300) {
        Some(v) -> {
            assert_eq(v, 100)
        },
        None -> {
            assert_true(false)
        },
    }
}
